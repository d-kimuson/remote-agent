{
  "name": "@kimuson/remote-agent",
  "version": "0.0.1",
  "private": false,
  "description": "A CLI that serves a web UI for interacting with ACP-compatible agents",
  "bin": {
    "remote-agent": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/cli.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "portless --name 'remote-agent' node ./dist/cli.mjs",
    "dev": "pnpm dev:proxy && run-p dev:web dev:server",
    "dev:proxy": "node --experimental-strip-types src/scripts/ensure-portless-proxy.ts",
    "dev:server": "RA_DIR=./data/.ra-dir RA_RUNTIME=dev portless --name 'remote-agent-server' --force node --watch src/server/main.ts",
    "dev:web": "SERVER_BASE_URL=$(pnpm portless get remote-agent-server) portless --name 'remote-agent-web' --force vite",
    "build": "run-s build:server build:web build:openapi",
    "build:openapi": "node --experimental-strip-types src/scripts/write-openapi.ts dist/openapi.json",
    "build:server": "tsdown",
    "build:web": "vite build",
    "typecheck": "tsgo -p . --noEmit",
    "fix": "run-p fix:*",
    "fix:oxfmt": "oxfmt --ignore-path .gitignore --no-error-on-unmatched-pattern",
    "fix:oxlint": "pnpm lint:oxlint --fix",
    "lint": "run-p lint:*",
    "lint:oxfmt": "pnpm fix:oxfmt --check",
    "lint:oxlint": "oxlint --ignore-path .gitignore --no-error-on-unmatched-pattern",
    "migrate:generate": "drizzle-kit generate",
    "migrate:local": "node --experimental-strip-types src/scripts/migrate-local.ts",
    "generate:db-docs": "drizzle-docs generate ./src/server/db/schema.ts -d sqlite >> ./docs/database.md",
    "prepack": "./scripts/prepare-publish.sh",
    "smoke:pack": "pnpm build && node --experimental-strip-types src/scripts/smoke-packed-package.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "0.30.0",
    "@zed-industries/codex-acp": "0.11.1",
    "pi-acp": "0.0.26"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "0.14.1",
    "@base-ui/react": "1.4.1",
    "@fontsource-variable/geist": "5.2.8",
    "@hono/node-server": "2.0.0",
    "@hono/standard-validator": "0.2.2",
    "@mcpc-tech/acp-ai-provider": "0.3.2",
    "@react-native-async-storage/async-storage": "3.0.2",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/react-query": "5.99.2",
    "@tanstack/react-router": "1.168.23",
    "@tanstack/router-plugin": "1.167.22",
    "@testing-library/react": "16.3.2",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@valibot/to-json-schema": "1.6.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "4.1.5",
    "ai": "6.0.168",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "commander": "14.0.3",
    "drizzle-docs-generator": "0.7.2",
    "drizzle-kit": "1.0.0-beta.20",
    "drizzle-orm": "1.0.0-beta.20",
    "gatecheck": "0.0.1-beta.5",
    "hono": "4.12.14",
    "hono-openapi": "1.3.0",
    "lefthook": "2.1.6",
    "lucide-react": "1.8.0",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "playwright": "1.59.1",
    "portless": "0.10.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.73.1",
    "react-markdown": "10.1.0",
    "react-native": "0.85.2",
    "remark-gfm": "4.0.1",
    "shadcn": "4.4.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.4",
    "tsdown": "0.21.10",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "valibot": "1.3.1",
    "vite": "8.0.9",
    "vite-plugin-pwa": "1.1.0",
    "vitest": "4.1.5",
    "workbox-precaching": "7.4.0",
    "workbox-routing": "7.4.0",
    "workbox-window": "7.4.0",
    "zod": "3.25.76"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
