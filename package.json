{
  "name": "acp-playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "run-s build:web typecheck",
    "build:web": "vite build",
    "dev": "run-p dev:web dev:server",
    "dev:server": "portless --name 'acp-hono' node --watch src/main.ts",
    "dev:web": "SERVER_BASE_URL=$(pnpm portless get acp-hono) portless --name 'acp-vite' vite",
    "fix": "run-p fix:*",
    "fix:oxfmt": "oxfmt --ignore-path .gitignore --no-error-on-unmatched-pattern",
    "fix:oxlint": "pnpm lint:oxlint --fix",
    "lint": "run-p lint:*",
    "lint:oxfmt": "pnpm fix:oxfmt --check",
    "lint:oxlint": "oxlint --ignore-path .gitignore --no-error-on-unmatched-pattern",
    "prepare": "lefthook install",
    "test": "vitest run",
    "typecheck": "tsgo -p . --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.14.1",
    "@base-ui/react": "1.4.1",
    "@fontsource-variable/geist": "5.2.8",
    "@hono/node-server": "2.0.0",
    "@hono/standard-validator": "0.2.2",
    "@mcpc-tech/acp-ai-provider": "0.3.2",
    "@tanstack/react-query": "5.99.2",
    "@tanstack/react-router": "1.168.23",
    "@valibot/to-json-schema": "1.6.0",
    "ai": "6.0.168",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "hono": "4.12.14",
    "hono-openapi": "1.3.0",
    "lucide-react": "1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.73.1",
    "shadcn": "4.4.0",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/router-plugin": "1.167.22",
    "@testing-library/react": "16.3.2",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "4.1.5",
    "gatecheck": "0.0.1-beta.5",
    "lefthook": "2.1.6",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "playwright": "1.59.1",
    "portless": "0.10.3",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.0.9",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
